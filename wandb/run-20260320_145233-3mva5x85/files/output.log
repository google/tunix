    return (x + 1) ** 2

# Calculate g(4) and g(16)
g_4 = g(4)
g_16 = g(16)

# Calculate g(4) + g(16)
sum_g = g_4 + g_16

# Calculate g_inv(g(4) + g(16))
result = g_inv(sum_g)
print(result)
```
