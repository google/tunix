# Function to check if A is a power of B
func_isPowerOf() {
  local A=$1
  local B=$2
  if [[ A == B ]];then
    return 0
  fi
  if [[ B == 1 ]];then
    return 1
  fi
  if [[ A % B == 0 ]];then
    return $(func_isPowerOf  A B/B)
  fi
  return 1; #B is not the power of A
}

