        k = k % k
        l = k * l - 1
        count = 0
        r = 0
        for i in range(n, m + 1):
            if self.remainder(i, k) == k - 1:
                count += 1
        for i in range(k, k + m + 1):
            if self.remainder(i, k) == k - 1:
                count += 1
        return count
