# Calculate largest n
    for n_val in range(1, 1000):
        binomial = factorial(n_val) // (factorial(n_val - 3) * factorial(3))
        # Checking if it satisfies the given condition
        if binomial_coefficient * binomial < 10**6:
            largest_n = n_val

print(largest_n)
```
