```python
from math import floor

def find_position_of_k(k):
    i = 1
    position = 1
    while True:
        current_value = floor(i)
        if current_value == k:
            return position
        i += 1
        position += 1

def main():
    for k in range(1, 10):  # let's find positions for the numbers from 1 to 9
        k_position = find_position_of_k(k)
        print(f"The position of the first appearance of {k} is: {k_position}")

if __name__ == "__main__":
    main()
```

