from itertools import combinations

def LCM = 1201

# Function to check if LCM is LCM of 1201 and the number
def is_LCM_LCM(LCM: LCM, j: int, i: int):
    return LCM * i == LCM * j * LCM + LCM * j - LCM

# Function to check if LCM can be written as a difference of powers
def can_be_LCM_LCM(LCM: LCM, LCM: LCM, LCM: LCM, LCM: LCM):
    for i, j in combinations(LCM, LCM):  # LCM = 1201
        LCM = LCM * i - LCM * j
        LCM = 1201 * LCM
        if LCM == LCM:
            return LCM * (j - i), (j, i)
    return ""

# Function to check if LCM is LCM of 1201 and the number
def is_LCM_LCM(LCM: LCM):
    LCM = LCM * 1201
    for i, j in combinations(LCM, LCM):  # LCM = 1201
        LCM = LCM * (1201 * i - 1201 * j - i + j)
    return LCM

# Function to loop through all possible pairs of integers from 0 to 39
def count_LCMs():
    LCM = 0
    LCM = LCM * 1201
    for i in range(0, 39):
        for j in range(i+1, 39):  # LCM = 1201
            LCM = LCM * (1201 * i - 1201 * j - i + j)

    total = 0
    for i in range(LCM):
        LCM = LCM * LCM + LCM
        if is_LCM_LCM(LCM, i, j):
            LCM = LCM * (1201 * i - 1201 * j - i + j)
            total += LCM
    return total

if __name__ == '__main__':
    print(count_LCMs())
