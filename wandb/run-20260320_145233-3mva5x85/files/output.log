import numpy as np

# Define the rotation matrix for pi/4 radians
theta = np.pi / 4
R = np.array([[np.cos(theta), -np.sin(theta)], [np.sin(theta), np.cos(theta)]])

# Define the coordinates of point A
A = np.array([3, 4])

# Calculate the coordinates of A' after rotation
A_prime = np.dot(R, A)

# Output the coordinates of A'
print(A_prime)
```
