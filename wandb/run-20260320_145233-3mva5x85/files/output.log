# Defining the distances (dists) by multiplying the speeds by the time

distance_first_third = speed_first_third * time_per_seg  # 45 miles
distance_second_third = speed_second_third * time_per_seg  # 30 miles
distance_last_third = speed_last_third * time_per_seg  # 50 miles

# Sum of distances

total_distance = distance_first_third + distance_second_third + distance_last_third  # 90 miles
print(total_distance)
