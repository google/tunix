import math

# Define the infinite series sum using a fixed limit for comparison
def series_sum(terms):
    sum = 0
    for term in terms:
        sum += term / 3
    return sum

# Calculate the partial sums with different values of 'a'
def find_value_of_a(max_terms=1000):
    for value in range(10):
        current_term = (2 + (max_terms * value))
        series_sum_value = series_sum(range(1, max_terms))
        if abs(series_sum_value - 5) < 1e-4:
            return value

# Check the result
found_a = find_value_of_a()
print("The value of 'a' that makes the series converge to 5 is", found_a
