#!/usr/bin/env python
def decimal_to_fraction(decimal):
    # Convert the decimal to a fraction
    fraction = Decimal(decimal).as_integer_ratio()
    numerator, denominator = fraction
    # Simplify the fraction by dividing by the GCD
    gcd_num = math.gcd(numerator, denominator)
    simplified_fraction = (numerator // gcd_num, denominator // gcd_num)
    return simplified_fraction

