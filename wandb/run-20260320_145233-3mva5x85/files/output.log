# h = b * sin(A)

# Substituting the side lengths and solving a trigonometric equation with the known angles:
# a/b = 3/4 = \sin(A)
# Since this is a right triangle, we will get:
h = b * sp.sin(sp.pi/3)

# Simplifying and determining the height

h = b * sp.sin(sp.pi/3)
height = h.replace('x', 1)

height = sp.simplify(height)

print(height)
```
