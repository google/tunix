num_people_per_league = 5

# Number of champion teams in each league
num_champion_teams_per_league = 3

# Each person in one league shakes hands with the people in the other league who are champions
handshakes_per_person = num_league_2_champion_teams

# Total number of handshakes
total_handshakes = (num_people_per_league * num_league_2_champion_teams) * 2

print(total_handshakes)
```
