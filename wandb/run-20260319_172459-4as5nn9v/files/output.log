# Express the sum in terms of tangent
tan_expr = sp.atan(sum_sines_simplified)
tan_fraction = sp.Rational(tan_expr * 180 / sp.pi)

# Extract numerator and denominator
m, n = tan_fraction.as_numer_denom()

# Calculate m + n
result = m + n
print(result)
```
