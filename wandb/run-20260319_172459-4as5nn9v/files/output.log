# proj_v_on_3u = 3 * (u . v / v . v) * v

# Since u . v / u . u = 1 / (u . u) and u . v / v . v = k / (u . u * v . v)
# We can use the fact that proj_v_on_u = k / c * u, where k = u . v and c = u . u
# So proj_v_on_3u = 3 * (k / c) * u = 3 * proj_v_on_u

proj_v_on_3u = 3 * proj_v_on_u
print(proj_v_on_3u)

