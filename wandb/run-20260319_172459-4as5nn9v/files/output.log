    # Calculate the number of weeks Tom does his homework
    h = total_weeks - n
    # Calculate the total amount earned after n weeks of not doing homework
    total_earned = allowance_per_week * h - deduction_per_week * n
    # Check if the total earned is enough to buy the bike
    if initial_amount + total_earned >= bike_cost:
        max_non_homework_weeks = n
        break

print(max_non_homework_weeks)
```
