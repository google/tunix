\[ 2 = 1 - 2(z_1 z_2 + z_1 z_3 + \cdots + z_{n-1} z_n) \]
\[ 1 = -2(z_1 z_2 + z_1 z_3 + \cdots + z_{n-1} z_n) \]
\[ z_1 z_2 + z_1 z_3 + \cdots + z_{n-1} z_n = -\frac{1}{2} \]
