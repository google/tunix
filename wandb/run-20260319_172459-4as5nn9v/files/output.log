# Substitute the points into the equation
point1 = Eq(f, 0)
point2 = Eq(2**2 + 1**2 + (-4)**2 + e*(-4) + f, 0)
point3 = Eq(5**2 + 8**2 + (-3)**2 + e*(-3) + f, 0)

# Solve the system of equations
solutions = solve((point1, point2, point3), (e, f))
print(solutions)
```
