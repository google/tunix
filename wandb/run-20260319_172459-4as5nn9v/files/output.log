    return lamb**k.imag >= 0

# Find the smallest m such that lambda^m has a nonnegative imaginary part
m = 1
while not nonnegative_imaginary(lamb, m):
    m += 1

# Find the smallest n > m such that lambda^n has a nonnegative imaginary part
n = m + 1
while not (nonnegative_imaginary(lamb, n)):
    n += 1

# Calculate n - m
result = n - m
print((m, n, result))
```
