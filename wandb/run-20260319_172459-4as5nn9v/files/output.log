# Radius of the semicircular arcs
r = s / 2

# Area of one semicircular arc
area_semicircle = (1/2) * math.pi * r**2

# Total area of four semicircular arcs
total_area_semicircles = 4 * area_semicircle

# Area of the region enclosed by the semicircular arcs and the two remaining sides of the hexagon
area_region = area_hexagon - total_area_semicircles

print(area_region)
```
