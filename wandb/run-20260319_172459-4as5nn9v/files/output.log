    p1_plus_p2 = 2 * x**2 + 2 * (3**x)
    return p1_plus_p2 % 7

# Test for x = 7k, where k is an integer
results = []
for k in range(1, 11):  # Testing for k from 1 to 10
    x = 7 * k
    result = p1_plus_p2_mod_7(x)
    results.append((x, result))

print(results)
```
