# If the roots form a valid triangle, calculate the area using Heron's formula
if is_valid_triangle:
    a, b, c = r, s, t
    s = (a + b + c) / 2  # semi-perimeter
    area = np.sqrt(s * (s - a) * (s - b) * (s - c))
else:
    area = None  # Invalid triangle

print(area)
```
