equation = sp.cos(4*x) + sp.cos(3*x)**2 + sp.cos(2*x)**3 + sp.cos(x)**4

# Find the roots of the equation in the interval [-pi, pi]
solutions = sp.solveset(equation, x, domain=sp.Interval(-sp.pi, sp.pi))

# The number of solutions
num_solutions = len(solutions)
print(num_solutions)
```
