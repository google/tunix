    test_point = (interval[0] + interval[1]) / 2
    return expr.subs(x, test_point)

# Expression to test
expression = (4*x**3 - 9*x**2 - 8*x - 3) / (4*(x+1)*(x-1))

# Determine where the expression is non-negative
solution_intervals = []
for interval in intervals:
    if test_interval(expression, interval) >= 0:
        solution_intervals.append(interval)

print(solution_intervals)
```
