def find_exact_x():
    for x in range(1000, 10000):  # Using a high range to cover the interval [8, 9)
        x_value = 8 + x / 10000.0
        if math.floor(x_value) + math.ceil(x_value) == 17:
            return x_value

# Find the exact value of x
exact_x_value = find_exact_x()
print(exact_x_value)
```
