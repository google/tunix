def geometric_sequence_length(a1, r, stop_value):
    n = 1
    term = a1
    while term >= stop_value:
        n += 1
        term *= r
    return n - 1  # subtract 1 because we overstep the condition in the loop

# Function to find the number of terms in an arithmetic sequence
def arithmetic_sequence_length(a1, d, stop_value):
    n = 1
    term = a1
    while term >= stop_value:
        n += 1
        term += d
    return n - 1  # subtract 1 because we overstep the condition in the loop

